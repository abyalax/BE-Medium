@model Medium.Api.Infrastructure.Email.Models.CommentCreatedEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Comment on Your Article</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #24292e; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; background-color: #f9f9f9; }
        .comment-box { background-color: white; padding: 15px; border-left: 4px solid #0366d6; margin: 15px 0; }
        .commenter-name { font-weight: bold; color: #0366d6; }
        .comment-text { margin-top: 10px; }
        .button { display: inline-block; padding: 12px 24px; background-color: #0366d6; color: white; text-decoration: none; border-radius: 4px; }
        .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>New Comment on Your Article</h1>
        </div>
        <div class="content">
            <p>Hi @Model.AuthorName,</p>
            <p>@Model.CommenterName left a comment on your article "@Model.ArticleTitle":</p>
            <div class="comment-box">
                <div class="commenter-name">@Model.CommenterName</div>
                <div class="comment-text">@Model.CommentContent</div>
            </div>
            <p>
                <a href="@Model.CommentUrl" class="button">View Comment</a>
            </p>
        </div>
        <div class="footer">
            <p>&copy; @DateTime.UtcNow.Year Medium Clone. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
