@model Medium.Api.Infrastructure.Email.Models.UserFollowedEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Follower</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #24292e; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; background-color: #f9f9f9; }
        .follower-info { background-color: white; padding: 15px; border-radius: 4px; margin: 15px 0; text-align: center; }
        .follower-name { font-size: 20px; font-weight: bold; color: #0366d6; }
        .button { display: inline-block; padding: 12px 24px; background-color: #0366d6; color: white; text-decoration: none; border-radius: 4px; margin: 10px 5px; }
        .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>New Follower</h1>
        </div>
        <div class="content">
            <p>Hi @Model.FollowingName,</p>
            <p>You have a new follower!</p>
            <div class="follower-info">
                <div class="follower-name">@Model.FollowerName</div>
            </div>
            <p>
                <a href="@Model.FollowerProfileUrl" class="button">View Profile</a>
                <a href="@Model.FollowBackUrl" class="button">Follow Back</a>
            </p>
        </div>
        <div class="footer">
            <p>&copy; @DateTime.UtcNow.Year Medium Clone. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
