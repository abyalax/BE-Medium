@model Medium.Api.Infrastructure.Email.Models.NewsletterEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weekly Newsletter</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #24292e; color: white; padding: 20px; text-align: center; }
        .content { padding: 20px; background-color: #f9f9f9; }
        .stats { display: flex; justify-content: space-around; margin: 20px 0; }
        .stat-item { text-align: center; }
        .stat-number { font-size: 32px; font-weight: bold; color: #0366d6; }
        .stat-label { font-size: 14px; color: #666; }
        .article-item { background-color: white; padding: 15px; margin: 10px 0; border-radius: 4px; }
        .article-title { font-weight: bold; color: #0366d6; }
        .article-author { font-size: 12px; color: #666; }
        .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Weekly Newsletter</h1>
            <p>@Model.WeekStartDate - @Model.WeekEndDate</p>
        </div>
        <div class="content">
            <h2>This Week's Highlights</h2>
            <div class="stats">
                <div class="stat-item">
                    <div class="stat-number">@Model.NewArticlesCount</div>
                    <div class="stat-label">New Articles</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">@Model.NewCommentsCount</div>
                    <div class="stat-label">New Comments</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">@Model.NewFollowersCount</div>
                    <div class="stat-label">New Followers</div>
                </div>
            </div>
            
            @if (Model.TopArticles.Any())
            {
                <h3>Top Articles This Week</h3>
                foreach (var article in Model.TopArticles)
                {
                    <div class="article-item">
                        <div class="article-title">@article.Title</div>
                        <div class="article-author">by @article.AuthorName</div>
                        <a href="@article.Url">Read more</a>
                    </div>
                }
            }
            
            <p>
                <a href="@Model.SiteUrl" class="button">Visit Medium Clone</a>
            </p>
        </div>
        <div class="footer">
            <p>You're receiving this email because you subscribed to our newsletter.</p>
            <p>&copy; @DateTime.UtcNow.Year Medium Clone. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
