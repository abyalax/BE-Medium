{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Medium.Api": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-super-secret-key-minimum-32-characters-long",
